// StoreHub — multi-vendor marketplace + storefront platform

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  VENDOR
  ADMIN
}

enum VendorCategory {
  PHYSICAL_GOODS
  DIGITAL_PRODUCTS
  REAL_ESTATE
  SERVICES
  AUTHORS_CREATORS
  PORTFOLIO_GENERAL
}

enum VendorStatus {
  ACTIVE
  SUSPENDED
  BANNED
}

enum SubscriptionTier {
  FREE
  STARTER
  PRO
  BUSINESS
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum ProductStatus {
  DRAFT
  ACTIVE
  OUT_OF_STOCK
  ARCHIVED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model User {
  id           String   @id @default(cuid())
  email        String?  @unique
  phone        String?  @unique
  passwordHash String?  @map("password_hash")
  name         String?
  role         UserRole @default(CUSTOMER)
  isSuspended  Boolean  @default(false) @map("is_suspended")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  vendor Vendor?
  orders Order[]

  @@map("users")
}

model Vendor {
  id                     String             @id @default(cuid())
  userId                 String             @unique @map("user_id")
  businessName           String             @map("business_name")
  category               VendorCategory
  username               String             @unique
  status                 VendorStatus       @default(ACTIVE)
  isVerified             Boolean            @default(false) @map("is_verified")
  paystackSubaccountCode String?            @map("paystack_subaccount_code")
  subscriptionTier       SubscriptionTier   @default(FREE) @map("subscription_tier")
  subscriptionStatus     SubscriptionStatus @default(ACTIVE) @map("subscription_status")
  createdAt              DateTime           @default(now()) @map("created_at")
  updatedAt              DateTime           @updatedAt @map("updated_at")

  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  products          Product[]
  orders            Order[]
  subscriptions     Subscription[]
  storefrontSetting StorefrontSettings?
  notices           VendorNotice[]

  @@index([category])
  @@index([status])
  @@map("vendors")
}

model Product {
  id             String        @id @default(cuid())
  vendorId       String        @map("vendor_id")
  title          String
  description    String?
  price          Decimal       @db.Decimal(12, 2)
  images         String[]
  categoryFields Json?         @map("category_fields")
  stockCount     Int?          @map("stock_count")
  status         ProductStatus @default(DRAFT)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([status])
  @@map("products")
}

model Order {
  id                String        @id @default(cuid())
  customerId        String        @map("customer_id")
  vendorId          String        @map("vendor_id")
  items             Json
  totalAmount       Decimal       @map("total_amount") @db.Decimal(12, 2)
  paymentStatus     PaymentStatus @default(PENDING) @map("payment_status")
  paystackReference String?       @unique @map("paystack_reference")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  customer User   @relation(fields: [customerId], references: [id], onDelete: Restrict)
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Restrict)

  @@index([customerId])
  @@index([vendorId])
  @@map("orders")
}

model Subscription {
  id               String             @id @default(cuid())
  vendorId         String             @map("vendor_id")
  tier             SubscriptionTier
  paystackPlanCode String?            @map("paystack_plan_code")
  status           SubscriptionStatus @default(ACTIVE)
  nextBillingDate  DateTime?          @map("next_billing_date")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@map("subscriptions")
}

model StorefrontSettings {
  id          String   @id @default(cuid())
  vendorId    String   @unique @map("vendor_id")
  templateId  String   @default("minimal") @map("template_id")
  logoUrl     String?  @map("logo_url")
  brandColor  String?  @map("brand_color")
  bioText     String?  @map("bio_text")
  socialLinks Json?    @map("social_links")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@map("storefront_settings")
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("announcements")
}

model VendorNotice {
  id        String   @id @default(cuid())
  vendorId  String   @map("vendor_id")
  title     String
  body      String
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@map("vendor_notices")
}

model PlatformSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}
